---
const socials = [
  { label: 'GitHub', href: 'https://github.com' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/matthijs-ten-brink-7620612a8/' },
];
---

<footer class="site-footer">
  <span class="text-label site-footer__copy">© 2026 — Matthijs ten Brink</span>

  <nav class="site-footer__socials" >
    <ul class="site-footer__social-list">
      {socials.map(social => (
        <li>
          <a
            href={social.href}
            class="text-label site-footer__social-link"
            target="_blank"          
            >
            {social.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</footer>

<style>
  .site-footer {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-inline: 1.5rem;
    padding-block: 2rem;
    border-top: 1px solid var(--color-divider);
  }

  .site-footer__copy {
    color: var(--color-muted);
  }

  .site-footer__social-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .site-footer__social-link {
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .site-footer__social-link:hover {
    color: var(--color-text);
  }

  @media (min-width: 600px) {
    .site-footer {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      padding-inline: 3rem;
    }
  }
</style>
