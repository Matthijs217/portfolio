---
import SectionLabel from '../atoms/SectionLabel.astro';

---

<section class="cta-section" id="contact">
  <SectionLabel index="05" title="Contact" />
  <h2 class="cta-section__heading text-hero">
    Let's
    <em class="cta-section__italic">build</em>
    something.
  </h2>

  <a href="mailto:matthijstenbrink@gmail.com" class="cta-section__email text-email">
    matthijstenbrink@gmail.com
    <span aria-hidden="true">↗</span>
  </a>
</section>

<style>
  .cta-section {
    padding-inline: 1.5rem;
    padding-block: 5rem;
  }

  .cta-section__label {
    color: var(--color-muted);
    margin-bottom: 1.5rem;
    display: block;
  }

  .cta-section__heading {
    display: block;
    margin-bottom: 2rem;
    line-height: 0.9;
    text-transform: uppercase;
  }

  .cta-section__italic {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    text-transform: none;
  }

  .cta-section__email {
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 1px solid var(--color-divider);
    padding-bottom: 0.25rem;
    transition: border-color 0.2s;
  }

  .cta-section__email:hover {
    border-color: var(--color-text);
  }

  @media (min-width: 600px) {
    .cta-section {
      padding-inline: 3rem;
    }
  }
</style>
