---
const { href, label, ariaLabel } = Astro.props;
---

<a
  href={href}
  class="arrow-link text-label"
  aria-label={ariaLabel}
>
  {label && <span>{label}</span>}
  <span class="arrow-link__icon" aria-hidden="true">{label ? '↗' : '→'}</span>
</a>

<style>
  .arrow-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    color: var(--color-text);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .arrow-link::before {
    content: '';
    position: absolute;
    inset: 0;
  }

  .arrow-link:hover {
    opacity: 0.6;
  }
</style>
