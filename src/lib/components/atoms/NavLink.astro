---
interface Props {
  href: string;
  label: string;
}

const { href, label } = Astro.props;
---

<a href={href} class="nav-link text-nav">{label}</a>

<style>
  .nav-link {
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-link:hover {
    color: var(--color-muted);
  }
</style>
